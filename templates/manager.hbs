<div class="bg3-craft-container">
    
    <div class="craft-sidebar">
        <h3><i class="fas fa-radar"></i> Радар Замков</h3>
        
        <div class="recipe-list">
            {{#if hasTargets}}
                
                <!-- Сундуки -->
                <div class="global-category">
                    <div class="global-header" data-action="toggleCategory" data-category="chests" style="cursor: pointer;" title="Свернуть/Развернуть">
                        <span class="category-icon"><i class="fas fa-box-open"></i></span>
                        <span class="category-name">Сундуки</span>
                        <span class="subcategory-recipe-count">{{chests.length}}</span>
                        <!-- Иконка стрелочки, которая меняется в зависимости от состояния -->
                        <i class="fas fa-chevron-{{#if expanded.chests}}down{{else}}right{{/if}}" style="margin-left: 8px; font-size: 0.85em; color: var(--thm-text-muted);"></i>
                    </div>
                    {{#if expanded.chests}}
                    <div class="group-content">
                        {{#each chests}}
                        <div class="category-btn {{#if this.isSelected}}active{{/if}} recipe-item" 
                             data-action="selectTarget" data-id="{{this.id}}" data-type="{{this.type}}">
                            <span style="display:flex; align-items:center; gap:8px;">
                                {{#if this.img}}<img src="{{this.img}}" width="24" height="24" style="border-radius:4px; border:1px solid #000;">{{/if}}
                                {{this.name}}
                            </span>
                            <div>
                                <i class="fas {{#if this.isLocked}}fa-lock{{else}}fa-lock-open{{/if}}" 
                                   style="color:{{#if this.isLocked}}#e84118{{else}}#4cd137{{/if}}; margin-right:5px; cursor: pointer;" 
                                   data-action="toggleLock" data-id="{{this.id}}" data-type="{{this.type}}" data-locked="{{this.isLocked}}" title="Нажмите, чтобы переключить замок"></i>
                                <i class="fas fa-crosshairs knowledge-toggle known" 
                                   data-action="pingTarget" data-id="{{this.id}}" data-type="{{this.type}}" title="Показать на карте"></i>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                </div>

                <!-- Двери -->
                <div class="global-category">
                    <div class="global-header" style="margin-top: 10px; cursor: pointer;" data-action="toggleCategory" data-category="doors" title="Свернуть/Развернуть">
                        <span class="category-icon"><i class="fas fa-door-closed"></i></span>
                        <span class="category-name">Двери</span>
                        <span class="subcategory-recipe-count">{{doors.length}}</span>
                        <!-- Иконка стрелочки -->
                        <i class="fas fa-chevron-{{#if expanded.doors}}down{{else}}right{{/if}}" style="margin-left: 8px; font-size: 0.85em; color: var(--thm-text-muted);"></i>
                    </div>
                    {{#if expanded.doors}}
                    <div class="group-content">
                        {{#each doors}}
                        <div class="category-btn {{#if this.isSelected}}active{{/if}} recipe-item" 
                             data-action="selectTarget" data-id="{{this.id}}" data-type="{{this.type}}">
                            <span>{{this.name}}</span>
                            <div>
                                <i class="fas {{#if this.isLocked}}fa-lock{{else}}fa-lock-open{{/if}}" 
                                   style="color:{{#if this.isLocked}}#e84118{{else}}#4cd137{{/if}}; margin-right:5px; cursor: pointer;" 
                                   data-action="toggleLock" data-id="{{this.id}}" data-type="{{this.type}}" data-locked="{{this.isLocked}}" title="Нажмите, чтобы переключить замок"></i>
                                <i class="fas fa-crosshairs knowledge-toggle known" 
                                   data-action="pingTarget" data-id="{{this.id}}" data-type="{{this.type}}" title="Показать на карте"></i>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{/if}}
                </div>

            {{else}}
                <div style="padding: 15px; text-align: center; color: #dcb174; opacity: 0.7;">
                    На текущей сцене нет дверей или сундуков.
                </div>
            {{/if}}
        </div>
    </div>

    <div class="craft-workspace">
        {{#if selected}}
            <h2 class="section-title">
                {{#if (eq selected.type 'door')}}
                    <i class="fas fa-door-closed"></i> Настройки Двери
                {{else}}
                    <i class="fas fa-box-open"></i> Настройки Сундука
                {{/if}}
                <br>
                <span style="font-size: 0.6em; color: #b8a88a;">{{selected.name}}</span>
            </h2>

            <div class="craft-stage">
                <p style="text-align:center; color:#f0d8a7; margin-bottom:15px;">Перетащите сюда предмет, чтобы назначить его ключом:</p>
                
                <div class="components-area" style="margin-top: 10px; margin-bottom: 20px;">
    <div class="slot-container" style="position: relative;">
        {{#if selected.settings.key}}
        <i class="fas fa-times-circle" data-action="removeKey" style="position: absolute; top: -10px; right: -10px; color: #e84118; font-size: 1.5em; cursor: pointer; z-index: 10; background: #1a1814; border-radius: 50%;" title="Удалить ключ"></i>
        {{/if}}

        <div class="item-slot {{#if selected.settings.key}}valid{{/if}}" data-drop-zone="true">
            {{#if selected.settings.key}}
                <img src="{{selected.settings.key.img}}" class="slot-image" title="{{selected.settings.key.name}}">
            {{else}}
                <i class="fas fa-key" style="font-size: 2em; color: #b8a88a; opacity: 0.7;"></i>
            {{/if}}
        </div>
        <span class="slot-label">{{#if selected.settings.key}}{{selected.settings.key.name}}{{else}}Бросьте ключ сюда{{/if}}</span>
    </div>
</div>

<div class="recipe-discovery" style="display: flex; flex-direction: column; align-items: center; padding: 20px 15px; box-sizing: border-box;">
    
    <div style="display: flex; justify-content: center; gap: 40px; margin-bottom: 20px; width: 100%;">
        <div style="display: flex; flex-direction: column; align-items: center;">
            <span style="color: #f0d8a7; font-weight: bold; margin-bottom: 8px; font-size: 1.1em; letter-spacing: 0.5px;">Сложность (DC)</span>
            <input type="number" id="nock-dc" value="{{selected.settings.dc}}" style="width: 70px; height: 34px; font-size: 1.2em; background: rgba(0,0,0,0.6); border: 1px solid #dcb174; color: #f39c12; text-align: center; border-radius: 4px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);">
        </div>
        <div style="display: flex; flex-direction: column; align-items: center;">
            <span style="color: #f0d8a7; font-weight: bold; margin-bottom: 8px; font-size: 1.1em; letter-spacing: 0.5px;" title="0 или пусто = бесконечно">Попытки</span>
            <input type="number" id="nock-attempts" value="{{selected.settings.maxAttempts}}" placeholder="∞" style="width: 70px; height: 34px; font-size: 1.2em; background: rgba(0,0,0,0.6); border: 1px solid #dcb174; color: #e84118; text-align: center; border-radius: 4px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);">
        </div>
    </div>
    
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; width: 100%;">
        {{#each statsList as |stat|}}
        <label class="bmc-minigame-toggle" style="cursor: pointer; margin: 0;">
            <input type="checkbox" id="nock-{{stat.id}}" {{#if (lookup ../selected.settings.allowedStats stat.id)}}checked{{/if}}>
            <span><i class="fas {{#if (eq stat.id 'str')}}fa-hand-rock{{else if (eq stat.id 'dex')}}fa-hands{{else if (eq stat.id 'int')}}fa-brain{{else}}fa-cog{{/if}}"></i> {{stat.label}}</span>
        </label>
        {{/each}}
    </div>
</div>
            </div>

            <div class="controls-area">
                <button class="bg3-btn main-action" type="button" data-action="saveSettings">
                    <i class="fas fa-save"></i> СОХРАНИТЬ НАСТРОЙКИ
                </button>
            </div>
        {{else}}
            <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; opacity:0.5;">
                <i class="fas fa-unlock-alt" style="font-size: 5em; margin-bottom: 20px;"></i>
                <h2 class="section-title">Выберите объект слева</h2>
            </div>
        {{/if}}
    </div>

</div>
