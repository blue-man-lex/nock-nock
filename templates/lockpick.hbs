<div class="nock-lockpick-container">
    
    <div class="nock-header">
        {{#if isJammed}}
            <span class="nock-label" style="color: #e84118;">СТАТУС ЗАМКА:</span>
            <div class="nock-dc-value" style="color: #e84118; font-size: 2.2em; letter-spacing: 2px;">ЗАКЛИНИЛО</div>
        {{else}}
            <span class="nock-label">{{#if isCPR}}СЛОЖНОСТЬ (DV):{{else}}СЛОЖНОСТЬ (DC):{{/if}}</span>
            <div class="nock-dc-value">{{flags.dc}}</div>
        {{/if}}
    </div>

    {{#if hasKey}}
    <div class="nock-key-area">
        <button class="bg3-btn nock-key-btn" data-action="useKey">
            <img src="{{keyData.img}}">
            <span>ИСПОЛЬЗОВАТЬ КЛЮЧ</span>
        </button>
    </div>
    {{/if}}

    <div class="dice-core-zone">
        {{#if (not (eq remainingAttempts "∞"))}}
            <div title="Осталось попыток" style="position: absolute; left: 15px; top: 15px; display: flex; flex-direction: column; align-items: center; background: rgba(0,0,0,0.5); padding: 8px; border-radius: 8px; border: 1px solid {{#if isJammed}}#e84118{{else}}#dcb174{{/if}};">
                <i class="fas fa-tools" style="font-size: 1.5em; color: {{#if isJammed}}#e84118{{else}}#dcb174{{/if}};"></i>
                <span style="font-size: 1.2em; font-weight: bold; margin-top: 5px; color: {{#if isJammed}}#e84118{{else}}#fff{{/if}};">{{remainingAttempts}}</span>
            </div>
        {{/if}}
        
        {{#if isJammed}}
            <div class="roll-circle" style="border-color: #e84118 !important; cursor: not-allowed; opacity: 0.5; box-shadow: inset 0 0 20px rgba(232, 65, 24, 0.2);">
                 <i class="fas fa-times" style="color: #e84118;"></i>
            </div>
        {{else}}
            <div class="roll-circle" data-action="rollDice">
                 <i class="fas {{#if isCPR}}fa-dice-d10{{else}}fa-dice-d20{{/if}}"></i>
            </div>
        {{/if}}
        
        {{#if toolName}}
            <div class="tool-detected">
                <i class="fas fa-toolbox"></i> {{toolName}} (+{{toolBonus}})
            </div>
        {{/if}}

        <div class="advantage-row">
            {{#if isCPR}}
                <!-- В CPR обычно нет преимущества, но оставим место для модификаторов если надо -->
            {{else}}
                <i class="fas fa-arrow-down {{#if (eq advantage -1)}}active-adv{{/if}}" data-action="toggleAdvantage" data-val="-1" title="Помеха"></i>
                <i class="fas fa-circle {{#if (eq advantage 0)}}active-adv{{/if}}" data-action="toggleAdvantage" data-val="0" title="Норма"></i>
                <i class="fas fa-arrow-up {{#if (eq advantage 1)}}active-adv{{/if}}" data-action="toggleAdvantage" data-val="1" title="Преимущество"></i>
            {{/if}}
        </div>
    </div>

    <div class="recipe-discovery">
        <div class="stat-buttons-row">
             {{#each statsList as |stat|}}
                {{#if (lookup ../allowedStats stat.id)}}
                <div class="bmc-minigame-toggle {{#if (eq ../selectedStat stat.id)}}active-stat{{/if}}" data-action="setStat" data-stat="{{stat.id}}">
                    <i class="{{#if stat.icon}}{{stat.icon}}{{else}}fas fa-cog{{/if}}"></i> 
                    {{stat.label}}
                </div>
                {{/if}}
            {{/each}}
        </div>

        <div class="bonus-footer">
            <span>Модификатор: <strong>+{{statMod}}</strong></span>
            <span class="separator">|</span>
            <span>Доп. бонус:</span>
            <input type="text" id="custom-bonus-text" value="{{bonusValue}}" placeholder="d4 / +2">
        </div>
    </div>
</div>

